# ============================================================
# Sudarshan — Production Environment Variables
# ============================================================
# INSTRUCTIONS:
#   1. Copy this file:  cp .env.production .env
#   2. Fill in ALL values below
#   3. NEVER commit the .env file to git
# ============================================================

# ── Flask ──────────────────────────────────────────────────
# Generate with: python3 -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=CHANGE_ME_generate_a_64_char_hex_string
FLASK_ENV=production
FLASK_DEBUG=0

# Set to your domain or VM public IP
SERVER_NAME=your-domain.com

# ── Database (Supabase PostgreSQL) ─────────────────────────
DATABASE_URL=postgresql+psycopg://postgres.YOUR_PROJECT:YOUR_PASSWORD@aws-1-ap-northeast-1.pooler.supabase.com:5432/postgres

# ── Redis ──────────────────────────────────────────────────
# Generate with: python3 -c "import secrets; print(secrets.token_urlsafe(32))"
REDIS_PASSWORD=CHANGE_ME_generate_a_strong_password

# ── Supabase Auth ──────────────────────────────────────────
SUPABASE_URL=https://YOUR_PROJECT.supabase.co
SUPABASE_ANON_KEY=your_anon_key_here
SUPABASE_SERVICE_KEY=your_service_key_here

# ── AI / LLM (Groq) ───────────────────────────────────────
GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL=llama-3.3-70b-versatile

# ── Security ───────────────────────────────────────────────
ALLOW_LOCAL_TARGETS=false
