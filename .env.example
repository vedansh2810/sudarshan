# ============================================================================
# Sudarshan Web Vulnerability Scanner — Environment Variables
# ============================================================================
#
# SETUP INSTRUCTIONS:
# 1. Copy this file to .env:       cp .env.example .env
# 2. Fill in the REQUIRED values below
# 3. Run the app:                  python run.py
#
# WHERE TO FIND SUPABASE CREDENTIALS:
#   Go to https://supabase.com/dashboard → your project → Settings → API
#   - Project URL        → SUPABASE_URL
#   - anon public key    → SUPABASE_ANON_KEY
#   - service_role secret → SUPABASE_SERVICE_KEY
#
# SUPABASE AUTH SETUP (one-time):
#   1. Dashboard → Authentication → URL Configuration
#      Add to Redirect URLs: http://localhost:5000/auth/callback-handler
#   2. Dashboard → Authentication → Providers
#      Enable "Email" provider (enabled by default)
#   3. (Optional) Enable Google provider for Google OAuth login
#
# ============================================================================

# ── Flask ────────────────────────────────────────────────────────────────────
# Generate a strong key:  python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-me-to-a-random-secret-key
FLASK_ENV=development
FLASK_DEBUG=1
PORT=5000

# Allow scanning localhost / private IP targets (set to true for DVWA testing)
ALLOW_LOCAL_TARGETS=false

# ── Database (PostgreSQL via Supabase) ───────────────────────────────────────
# If unreachable, the app falls back to SQLite at data/database.db automatically.
# For local-only development, you can leave this as-is (SQLite will be used).
DATABASE_URL=postgresql+psycopg://user:password@host:5432/dbname

# ── Redis (optional — required for Celery workers & SSE pub/sub) ─────────────
# If Redis is not available, the app falls back to in-process threading mode.
REDIS_PASSWORD=change-this-to-a-strong-password
REDIS_URL=redis://:change-this-to-a-strong-password@localhost:6379/0

# Celery (defaults to REDIS_URL if not set)
# CELERY_BROKER_URL=redis://:password@redis:6379/0
# CELERY_RESULT_BACKEND=redis://:password@redis:6379/0

# ── Supabase Auth (REQUIRED for user login/registration) ─────────────────────
# Without these, login and register pages will NOT work.
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_SERVICE_KEY=your-supabase-service-key

# ── AI / LLM (Groq — optional, AI features degrade gracefully) ──────────────
GROQ_API_KEY=your-groq-api-key
GROQ_MODEL=llama-3.3-70b-versatile
