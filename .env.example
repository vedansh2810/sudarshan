# Sudarshan Environment Configuration

# Flask secret key (REQUIRED in production)
SECRET_KEY=generate-a-strong-secret-key-here
FLASK_ENV=development

# Database (default: SQLite; set to PostgreSQL URI for production)
# DATABASE_URL=postgresql://user:pass@localhost:5432/sudarshan

# Redis (required for Celery background scans)
REDIS_URL=redis://localhost:6379/0

# Celery (defaults to REDIS_URL if not set)
# CELERY_BROKER_URL=redis://localhost:6379/0
# CELERY_RESULT_BACKEND=redis://localhost:6379/0